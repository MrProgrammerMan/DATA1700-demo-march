# Send a get request to OsloMets home page
GET / HTTP/1.1
Host: www.oslomet.no

# The ditio beta website
GET / HTTP/1.1
Host: beta.ditio.org

GET /assets/index-D_8Bc5vn.js HTTP/1.1
